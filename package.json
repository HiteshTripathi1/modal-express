{
  "name": "modal-express",
  "version": "0.0.1",
  "description": "Express + TypeScript port of the Modal Sandbox REST API POC",
  "type": "module",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc",
    "start:prod": "node dist/index.js",
    "sandbox": "tsx src/modal-sandbox.ts",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "express": "^5.1.0",
    "modal": "^0.8.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^24.0.0",
    "prettier": "^3.4.2",
    "tsx": "^4.22.4",
    "typescript": "^5.7.3"
  }
}
