# Application
APP_NAME=Modal POC
PORT=3000
API_PREFIX=api
NODE_ENV=development

# API auth — required on EVERY request as `Authorization: Bearer <key>` or
# `x-api-key: <key>`. Generate one with:  openssl rand -hex 32
# (leave empty to disable auth)
API_KEY=

# Modal credentials (create at https://modal.com/settings/tokens)
MODAL_TOKEN_ID=ak-xxxxxxxxxxxxxxxxxxxxxx
MODAL_TOKEN_SECRET=as-xxxxxxxxxxxxxxxxxxxxxx

# --- API flow (npm run start:dev) ---
# Repo details (repoUrl, token, branch, ...) are passed per-request to
# POST /api/previews — they are NOT read from the environment.

# --- CLI flow (npm run sandbox) ---
# The standalone one-shot script reads these from .env:
GIT_REPO_URL=https://github.com/owner/repo.git
GIT_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx   # GitHub PAT (required for private repos)
GIT_BRANCH=                          # empty = repo default branch
GIT_USER_NAME=Modal Sandbox
GIT_USER_EMAIL=sandbox@modal.local
APP_SUBDIR=                          # subfolder in the repo where the app lives (empty = root)
DEV_PORT=5173
# INSTALL_CMD=pnpm install
# DEV_CMD=pnpm run dev
# INJECT_ENV_FILE=/path/to/tenant.env  # dotenv file to inject into the clone (gitignored .env)
# INJECT_ENV_NAME=.env                 # filename to write it as inside the sandbox (default .env)

# --- Cloudflare (defaults for POST /api/sandboxes/:id/publish) ---
# Optional: the publish request body can override any of these per-call.
# Token needs Workers Scripts:Edit + the zone's Workers Routes:Edit + DNS:Edit.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=
